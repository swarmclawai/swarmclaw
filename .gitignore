# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# tool-generated screenshots
*-screenshot.png
*_screenshot.png
*_search.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# runtime data is always private (sessions, credentials, wallets, uploads, etc.)
/data/*
!/data/.gitkeep

# user config backup
/data-backup/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# CI artifacts
/artifacts/

# local scratch files
todo.html
IMPROVEMENTS.md
/agent-harness.md

# local scratch dir accidentally created by tooling
/~/
